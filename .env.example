# Server
PORT=5000
NODE_ENV=development

# MongoDB (Mongoose)
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/pinkdrive?retryWrites=true&w=majority

# PostgreSQL (Sequelize) — start via: docker compose up -d
DB_NAME=pinkdrive
DB_USER=pinkdrive_user
DB_PASSWORD=pinkdrive_pass
DB_HOST=localhost
DB_PORT=5432

# Auth
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173

# Email (Mailtrap recommended for dev — leave empty to log to console)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@pinkdrive.com

# Client (Vite)
VITE_API_URL=http://localhost:5000/api
